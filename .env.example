# WebSnap API environment configuration
# Copy to .env.local for local development

# Core
NEXT_PUBLIC_APP_URL=http://localhost:3000
WEBSNAP_SERVICE_NAME=websnap-api
WEBSNAP_ENV=development

# API keys
# Optional JSON array override for automated provisioning flows.
# Example:
# API_KEYS_JSON=[{"key":"wsnap_pro_123","name":"Acme","tier":"pro","enabled":true}]
API_KEYS_JSON=

# Plan quotas / references
FREE_DAILY_REQUESTS=100
PRO_MONTHLY_REQUESTS=10000
BUSINESS_MONTHLY_REQUESTS=100000

# API key naming hints
DEFAULT_FREE_KEY_PREFIX=wsnap_free_
DEFAULT_PRO_KEY_PREFIX=wsnap_pro_
DEFAULT_BUSINESS_KEY_PREFIX=wsnap_business_

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
WEBSNAP_BILLING_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_BUSINESS_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_CHECKOUT_LINK=
NEXT_PUBLIC_STRIPE_BUSINESS_CHECKOUT_LINK=
NEXT_PUBLIC_STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
NEXT_PUBLIC_STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel

# Ops automation
WEBSNAP_OPS_TOKEN=

# RapidAPI marketplace placeholder
RAPIDAPI_PROXY_SECRET=
RAPIDAPI_PROJECT_SLUG=websnap-api

# Vercel / deployment notes
VERCEL_PROJECT_NAME=websnap-api
VERCEL_TEAM_SLUG=
GITHUB_REPO_OWNER=Splaticusamz
GITHUB_REPO_NAME=websnap-api

# Stateless signed API key provisioning
WEBSNAP_API_KEY_SIGNING_SECRET=
